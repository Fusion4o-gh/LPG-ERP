{
  "name": "lpg-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "LPG management system for cylinder distribution, stock, accounting, and reporting.",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma migrate deploy && node -r ./scripts/patch-exfat-readlink.js ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "test:prepare": "node scripts/prepare-test-db.mjs",
    "test": "node scripts/prepare-test-db.mjs && node --import ./tests/helpers/test-env.mjs --test tests/*.test.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "framer-motion": "^12.40.0",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "embedded-postgres": "^18.3.0-beta.17",
    "postcss": "8.5.14",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
