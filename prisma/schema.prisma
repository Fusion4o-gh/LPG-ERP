generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  PRINT
  APPROVE
  CLOSE_DAY
  MANAGE_RBAC
}

enum CylinderState {
  FILLED
  EMPTY
}

enum StockDirection {
  IN
  OUT
}

enum TransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum CountStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  CANCELLED
}

enum StockSourceType {
  OPENING_BALANCE
  PURCHASE_FILLED
  SALE_LPG
  CYLINDER_RETURN
  PURCHASE_RETURN
  ADJUSTMENT
  WAREHOUSE_TRANSFER
  PHYSICAL_COUNT_ADJUSTMENT
}

enum PartyType {
  CUSTOMER
  VENDOR
  COMPANY
}

enum VoucherType {
  CP
  CR
  BP
  BR
  JV
  SR
  OPENING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  CLOSE_DAY
}

model Company {
  id                    String       @id @default(cuid())
  legalName             String
  tradeName             String?
  ownerName             String?
  address               String?
  phone                 String?
  email                 String?
  taxRegistrationNumber String?
  nationalTaxNumber     String?
  baseCurrency          String       @default("PKR")
  locale                String       @default("en")
  timeZone              String       @default("Asia/Karachi")
  stockAvailableCheck   Boolean      @default(true)
  centralizedPricing    Boolean      @default(false)
  showDefaultDate       Boolean      @default(true)
  redirectOnSamePage    Boolean      @default(false)
  workStartTime         String?
  workEndTime           String?
  workingDays           Json?
  status                RecordStatus @default(ACTIVE)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  users              User[]
  financialYears     FinancialYear[]
  cities             City[]
  chartAccounts      ChartAccount[]
  customers          Customer[]
  vendors            Vendor[]
  items              Item[]
  stockLedgerEntries StockLedgerEntry[]
  accountingVouchers AccountingVoucher[]
  auditLogs          AuditLog[]
  documentSequences  DocumentSequence[]
}

model FinancialYear {
  id        String    @id @default(cuid())
  companyId String
  label     String
  startsOn  DateTime  @db.Date
  endsOn    DateTime  @db.Date
  isActive  Boolean   @default(false)
  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  users              User[]
  stockLedgerEntries StockLedgerEntry[]
  accountingVouchers AccountingVoucher[]
  dayClosings        DayClosing[]
  documentSequences  DocumentSequence[]

  @@unique([companyId, label])
  @@index([companyId, isActive])
}

model User {
  id              String       @id @default(cuid())
  companyId       String
  financialYearId String?
  name            String
  loginId         String
  email           String?
  passwordHash    String?
  uiTheme         String       @default("aurora")
  status          RecordStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company             Company             @relation(fields: [companyId], references: [id])
  financialYear       FinancialYear?      @relation(fields: [financialYearId], references: [id])
  accounts            Account[]
  sessions            Session[]
  userRoles           UserRole[]
  userAreas           UserArea[]
  vouchersCreated     AccountingVoucher[] @relation("VoucherCreatedBy")
  stockEntriesCreated StockLedgerEntry[]  @relation("StockEntryCreatedBy")
  auditLogs           AuditLog[]
  dayClosings         DayClosing[]

  @@unique([companyId, loginId])
  @@unique([companyId, email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  description String?
  isSystem    Boolean      @default(false)
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([companyId, name])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Permission {
  id          String           @id @default(cuid())
  module      String
  action      PermissionAction
  description String?

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model City {
  id        String       @id @default(cuid())
  companyId String
  name      String
  status    RecordStatus @default(ACTIVE)

  company   Company    @relation(fields: [companyId], references: [id])
  areas     Area[]
  customers Customer[]
  vendors   Vendor[]

  @@unique([companyId, name])
}

model Area {
  id        String       @id @default(cuid())
  companyId String
  cityId    String
  name      String
  status    RecordStatus @default(ACTIVE)

  city      City       @relation(fields: [cityId], references: [id])
  customers Customer[]
  vendors   Vendor[]
  userAreas UserArea[]

  @@unique([cityId, name])
}

model UserArea {
  id     String @id @default(cuid())
  userId String
  areaId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([userId, areaId])
}

model Brand {
  id        String       @id @default(cuid())
  companyId String
  name      String
  status    RecordStatus @default(ACTIVE)

  items Item[]

  @@unique([companyId, name])
}

model Category {
  id                String       @id @default(cuid())
  companyId         String
  name              String
  status            RecordStatus @default(ACTIVE)
  isSystemProtected Boolean      @default(false)

  items Item[]

  @@unique([companyId, name])
}

model Item {
  id               String       @id @default(cuid())
  companyId        String
  code             String
  name             String
  categoryId       String
  brandId          String?
  cylinderWeightKg Decimal?     @db.Decimal(8, 2)
  defaultSecurity  Decimal      @default(0) @db.Decimal(14, 2)
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company                  Company                       @relation(fields: [companyId], references: [id])
  category                 Category                      @relation(fields: [categoryId], references: [id])
  brand                    Brand?                        @relation(fields: [brandId], references: [id])
  prices                   ItemPrice[]
  stockLedgerEntries       StockLedgerEntry[]
  customerCylinderBalances CustomerCylinderBalance[]
  vendorCylinderBalances   VendorCylinderReturnBalance[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model ItemPrice {
  id         String    @id @default(cuid())
  itemId     String
  customerId String?
  price      Decimal   @db.Decimal(14, 2)
  pricePerKg Decimal?  @db.Decimal(14, 4)
  validFrom  DateTime  @db.Date
  validTo    DateTime? @db.Date
  createdAt  DateTime  @default(now())

  item     Item      @relation(fields: [itemId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([itemId, customerId, validFrom])
}

model ChartAccount {
  id            String        @id @default(cuid())
  companyId     String
  code          String
  name          String
  parentId      String?
  level         Int
  accountType   AccountType
  normalBalance NormalBalance
  isControl     Boolean       @default(false)
  isSystem      Boolean       @default(false)
  status        RecordStatus  @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company      Company                 @relation(fields: [companyId], references: [id])
  parent       ChartAccount?           @relation("ChartAccountTree", fields: [parentId], references: [id])
  children     ChartAccount[]          @relation("ChartAccountTree")
  customers    Customer[]
  vendors      Vendor[]
  banks        Bank[]
  voucherLines AccountingVoucherLine[]

  @@unique([companyId, code])
  @@index([companyId, parentId])
}

model Customer {
  id               String       @id @default(cuid())
  companyId        String
  code             String
  name             String
  contactPerson    String?
  phone            String?
  cell             String?
  email            String?
  address          String?
  address2         String?
  cityId           String?
  areaId           String?
  segmentType      String?
  registrationDate DateTime?    @db.Date
  nationalTaxNumber String?
  gstNumber        String?
  creditDays       Int?
  accountId        String
  status           RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  company            Company                   @relation(fields: [companyId], references: [id])
  city               City?                     @relation(fields: [cityId], references: [id])
  area               Area?                     @relation(fields: [areaId], references: [id])
  account            ChartAccount              @relation(fields: [accountId], references: [id])
  prices             ItemPrice[]
  cylinderBalances   CustomerCylinderBalance[]
  stockLedgerEntries StockLedgerEntry[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model Vendor {
  id               String       @id @default(cuid())
  companyId        String
  code             String
  name             String
  contactPerson    String?
  phone            String?
  cell             String?
  email            String?
  address          String?
  cityId           String?
  areaId           String?
  segmentType      String?
  registrationDate DateTime?    @db.Date
  companyRegNo     String?
  vatNumber        String?
  creditDays       Int?
  accountId        String
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company            Company                       @relation(fields: [companyId], references: [id])
  city               City?                         @relation(fields: [cityId], references: [id])
  area               Area?                         @relation(fields: [areaId], references: [id])
  account            ChartAccount                  @relation(fields: [accountId], references: [id])
  cylinderBalances   VendorCylinderReturnBalance[]
  stockLedgerEntries StockLedgerEntry[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model Bank {
  id                 String       @id @default(cuid())
  companyId          String
  name               String
  accountId          String
  accountNumber      String?
  phone              String?
  address            String?
  email              String?
  openingBalance     Decimal?     @db.Decimal(14, 2)
  openingBalanceType String?
  status             RecordStatus @default(ACTIVE)

  account ChartAccount @relation(fields: [accountId], references: [id])

  @@unique([companyId, name])
}

model CustomerCylinderBalance {
  id                String   @id @default(cuid())
  customerId        String
  itemId            String
  filledOutstanding Int      @default(0)
  emptyOwed         Int      @default(0)
  securityHeld      Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt         DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])

  @@unique([customerId, itemId])
}

model VendorCylinderReturnBalance {
  id        String   @id @default(cuid())
  vendorId  String
  itemId    String
  emptyDue  Int      @default(0)
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])

  @@unique([vendorId, itemId])
}

model StockLedgerEntry {
  id              String          @id @default(cuid())
  companyId       String
  financialYearId String
  itemId          String
  cylinderState   CylinderState
  direction       StockDirection
  partyType       PartyType?
  customerId      String?
  vendorId        String?
  locationId      String?
  quantity        Int
  balanceAfter    Int
  sourceType      StockSourceType
  sourceId        String
  transactionDate DateTime        @db.Date
  remarks         String?
  createdById     String
  createdAt       DateTime        @default(now())

  company       Company       @relation(fields: [companyId], references: [id])
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])
  item          Item          @relation(fields: [itemId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])
  location      StockLocation? @relation(fields: [locationId], references: [id])
  createdBy     User          @relation("StockEntryCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, itemId, cylinderState, transactionDate])
  @@index([customerId, itemId, transactionDate])
  @@index([vendorId, itemId, transactionDate])
  @@index([sourceType, sourceId])
  @@index([companyId, itemId, cylinderState, locationId, transactionDate])
}

model WarehouseTransfer {
  id                    String          @id @default(cuid())
  companyId             String
  financialYearId       String
  documentNo            String          @unique
  transferDate          DateTime        @db.Date
  sourceLocationId      String
  destinationLocationId String
  status                TransferStatus  @default(DRAFT)
  remarks               String?
  createdById           String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  lines WarehouseTransferLine[]

  @@index([companyId, sourceLocationId])
  @@index([companyId, destinationLocationId])
  @@index([companyId, status])
}

model WarehouseTransferLine {
  id            String          @id @default(cuid())
  transferId    String
  itemId        String
  cylinderState CylinderState
  quantity      Int
  remarks       String?

  transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

model PhysicalCount {
  id              String       @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String       @unique
  locationId      String
  countDate       DateTime     @db.Date
  status          CountStatus  @default(DRAFT)
  notes           String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  lines PhysicalCountLine[]

  @@index([companyId, locationId])
  @@index([companyId, status])
}

model PhysicalCountLine {
  id              String        @id @default(cuid())
  physicalCountId String
  itemId          String
  cylinderState   CylinderState
  ledgerQuantity  Int           @default(0)
  countedQuantity Int           @default(0)
  variance        Int           @default(0)
  remarks         String?

  physicalCount PhysicalCount @relation(fields: [physicalCountId], references: [id], onDelete: Cascade)

  @@index([physicalCountId])
}

model AccountingVoucher {
  id              String      @id @default(cuid())
  companyId       String
  financialYearId String
  voucherNo       String
  voucherType     VoucherType
  voucherDate     DateTime    @db.Date
  narration       String?
  totalDebit      Decimal     @default(0) @db.Decimal(14, 2)
  totalCredit     Decimal     @default(0) @db.Decimal(14, 2)
  sourceType      String?
  sourceId        String?
  isPosted        Boolean     @default(true)
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company       Company                 @relation(fields: [companyId], references: [id])
  financialYear FinancialYear           @relation(fields: [financialYearId], references: [id])
  createdBy     User                    @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  lines         AccountingVoucherLine[]

  @@unique([companyId, voucherNo])
  @@index([companyId, voucherDate])
  @@index([sourceType, sourceId])
}

model AccountingVoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  accountId   String
  description String?
  debit       Decimal @default(0) @db.Decimal(14, 2)
  credit      Decimal @default(0) @db.Decimal(14, 2)
  sortOrder   Int     @default(0)

  voucher AccountingVoucher @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  account ChartAccount      @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

model DocumentSequence {
  id              String   @id @default(cuid())
  companyId       String
  financialYearId String
  prefix          String
  nextNumber      Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company       @relation(fields: [companyId], references: [id])
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])

  @@unique([companyId, financialYearId, prefix])
}

model DayClosing {
  id              String   @id @default(cuid())
  companyId       String
  financialYearId String
  closedDate      DateTime @db.Date
  closedById      String
  cashBalance     Decimal  @default(0) @db.Decimal(14, 2)
  notes           String?
  createdAt       DateTime @default(now())

  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])
  closedBy      User          @relation(fields: [closedById], references: [id])

  @@unique([companyId, closedDate])
}

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, entityType, entityId])
  @@index([companyId, createdAt])
}

// =============================================================================
// BULK / IMPORT / DOLLAR / PLANT EXTENSION
//
// This block adds the bulk LPG import-trading domain (Taftan/Ship imports,
// dollar contracts, plants, bowsers/transporters, partial receiving, sale &
// purchase contracts) on top of the existing cylinder-distribution core.
//
// Design notes (locked 2026-06-12):
//  - Bulk inventory uses a SEPARATE immutable ledger (BulkStockLedgerEntry).
//    The cylinder StockLedgerEntry is left untouched.
//  - Same company / unified GL: bulk stock, dollar gain/loss, and plant sales
//    post into the same ChartAccount / AccountingVoucher engine.
//  - New tables carry scalar FK ids (companyId, financialYearId, createdById,
//    vendorId, customerId, ...) WITHOUT Prisma relations to the core models, to
//    keep this module additive and avoid churn on Company/User/FinancialYear/
//    Vendor/Customer. Referential integrity is enforced in the service layer
//    (services fetch masters by id, matching the existing pattern). Relations
//    are declared only among the NEW models (parent -> child).
// =============================================================================

enum UnitOfMeasure {
  MT
  KG
  LITRE
}

enum BulkStockSourceType {
  OPENING_STOCK
  IMPORT_ARRIVAL
  LOADING
  LOCAL_PURCHASE
  PLANT_SALE
  FILLING_SALE
  DELIVERED_SALE
  PLANT_TRANSFER
  PARTIAL_RECEIVING
  DECANTING
  LOSS_GAIN
  DOLLAR_SALE
  ADJUSTMENT
}

enum ContractStatus {
  OPEN
  CLOSED
  CANCELLED
  APPROVED
  DISAPPROVED
}

enum ImportType {
  TAFTAN
  SHIP
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  ARRIVED
  RECEIVED
}

enum SaleContractStatus {
  OPEN
  PARTIAL
  DELIVERED
  CLOSED
  CANCELLED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  IN_TRANSIT
  MAINTENANCE
}

enum LocationType {
  PLANT
  IMPORT_TERMINAL
  IN_TRANSIT
  WAREHOUSE
}

enum DollarTxnType {
  PURCHASE
  SALE_WITH_CONTRACT
  SALE_WITHOUT_CONTRACT
  BULK_SALE
  PAYMENT
  RECEIPT
}

enum PlantSaleType {
  FILLING
  BULK
}

enum LossGainType {
  LOSS
  GAIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DISAPPROVED
}

model Transporter {
  id            String       @id @default(cuid())
  companyId     String
  code          String
  name          String
  contactPerson String?
  phone         String?
  address       String?
  ntn           String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  vehicles Vehicle[]
  drivers  Driver[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model Driver {
  id            String       @id @default(cuid())
  companyId     String
  transporterId String?
  name          String
  cell          String?
  cnic          String?
  licenseNo     String?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  transporter Transporter? @relation(fields: [transporterId], references: [id])
  vehicles    Vehicle[]

  @@unique([companyId, name, cell])
  @@index([companyId, name])
}

model Vehicle {
  id             String        @id @default(cuid())
  companyId      String
  transporterId  String?
  driverId       String?
  registrationNo String
  bowserCapacity Decimal?      @db.Decimal(14, 3)
  capacityUnit   UnitOfMeasure @default(MT)
  status         VehicleStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transporter Transporter? @relation(fields: [transporterId], references: [id])
  driver      Driver?      @relation(fields: [driverId], references: [id])

  @@unique([companyId, registrationNo])
  @@index([companyId, status])
}

model Plant {
  id        String       @id @default(cuid())
  companyId String
  code      String
  name      String
  cityId    String?
  location  String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stockLocations StockLocation[]

  @@unique([companyId, code])
  @@index([companyId, name])
}

model StockLocation {
  id        String       @id @default(cuid())
  companyId String
  plantId   String?
  code      String
  name      String
  type      LocationType @default(PLANT)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  plant              Plant? @relation(fields: [plantId], references: [id])
  stockLedgerEntries StockLedgerEntry[]

  @@unique([companyId, code])
  @@index([companyId, type])
}

model BulkProduct {
  id        String        @id @default(cuid())
  companyId String
  code      String
  name      String
  unit      UnitOfMeasure @default(MT)
  status    RecordStatus  @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([companyId, code])
  @@index([companyId, name])
}

model BulkStockLedgerEntry {
  id              String              @id @default(cuid())
  companyId       String
  financialYearId String
  productId       String
  locationId      String
  plantId         String?
  direction       StockDirection
  quantity        Decimal             @db.Decimal(16, 3)
  unit            UnitOfMeasure       @default(MT)
  balanceAfter    Decimal             @db.Decimal(16, 3)
  inTransit       Boolean             @default(false)
  sourceType      BulkStockSourceType
  sourceId        String
  partyType       PartyType?
  customerId      String?
  vendorId        String?
  transactionDate DateTime            @db.Date
  remarks         String?
  createdById     String
  createdAt       DateTime            @default(now())

  @@index([companyId, productId, locationId, transactionDate])
  @@index([companyId, inTransit])
  @@index([sourceType, sourceId])
}

model BulkOpeningStock {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  productId       String
  locationId      String
  quantity        Decimal       @db.Decimal(16, 3)
  unit            UnitOfMeasure @default(MT)
  valuationRate   Decimal       @default(0) @db.Decimal(16, 4)
  locked          Boolean       @default(false)
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, financialYearId, productId, locationId])
}

model ImportContract {
  id              String         @id @default(cuid())
  companyId       String
  financialYearId String
  contractNo      String
  contractDate    DateTime       @db.Date
  importType      ImportType
  vendorId        String
  productId       String
  purchaseType    String?
  quantity        Decimal        @db.Decimal(16, 3)
  unit            UnitOfMeasure  @default(MT)
  rateUsd         Decimal        @default(0) @db.Decimal(16, 4)
  exchangeRate    Decimal        @default(0) @db.Decimal(12, 4)
  amountUsd       Decimal        @default(0) @db.Decimal(16, 2)
  amountPkr       Decimal        @default(0) @db.Decimal(16, 2)
  status          ContractStatus @default(OPEN)
  remarks         String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  loadings Loading[]

  @@unique([companyId, contractNo])
  @@index([companyId, importType, status])
  @@index([companyId, contractDate])
}

model Loading {
  id               String         @id @default(cuid())
  companyId        String
  financialYearId  String
  contractId       String
  loadingType      ImportType
  loadingNo        String
  loadingDate      DateTime       @db.Date
  loadingLocation  String?
  vehicleId        String?
  transporterId    String?
  quantityLoaded   Decimal        @db.Decimal(16, 3)
  unit             UnitOfMeasure  @default(MT)
  rate             Decimal        @default(0) @db.Decimal(16, 4)
  freight          Decimal        @default(0) @db.Decimal(16, 2)
  finalRate        Decimal        @default(0) @db.Decimal(16, 4)
  stockLocationId  String?
  shipmentStatus   ShipmentStatus @default(IN_TRANSIT)
  arrivalDate      DateTime?      @db.Date
  arrivedQuantity  Decimal?       @db.Decimal(16, 3)
  remarks          String?
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  contract ImportContract @relation(fields: [contractId], references: [id])

  @@unique([companyId, loadingNo])
  @@index([companyId, shipmentStatus])
  @@index([contractId])
}

model PurchaseContract {
  id              String         @id @default(cuid())
  companyId       String
  financialYearId String
  contractNo      String
  contractDate    DateTime       @db.Date
  vendorId        String
  productId       String
  purchaseType    String?
  quantity        Decimal        @db.Decimal(16, 3)
  unit            UnitOfMeasure  @default(MT)
  rate            Decimal        @default(0) @db.Decimal(16, 4)
  amountPkr       Decimal        @default(0) @db.Decimal(16, 2)
  deliveredQty    Decimal        @default(0) @db.Decimal(16, 3)
  status          ContractStatus @default(OPEN)
  remarks         String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  localPurchases LocalPurchase[]

  @@unique([companyId, contractNo])
  @@index([companyId, status])
}

model LocalPurchase {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String
  contractId      String?
  vendorId        String
  productId       String
  locationId      String
  quantity        Decimal       @db.Decimal(16, 3)
  unit            UnitOfMeasure @default(MT)
  rate            Decimal       @default(0) @db.Decimal(16, 4)
  amount          Decimal       @default(0) @db.Decimal(16, 2)
  transactionDate DateTime      @db.Date
  voucherId       String?
  remarks         String?
  createdById     String
  createdAt       DateTime      @default(now())

  contract PurchaseContract? @relation(fields: [contractId], references: [id])

  @@unique([companyId, documentNo])
  @@index([companyId, transactionDate])
}

model SaleContract {
  id               String             @id @default(cuid())
  companyId        String
  financialYearId  String
  contractNo       String
  contractDate     DateTime           @db.Date
  customerId       String
  productId        String
  quantity         Decimal            @db.Decimal(16, 3)
  unit             UnitOfMeasure      @default(MT)
  rate             Decimal            @default(0) @db.Decimal(16, 4)
  amount           Decimal            @default(0) @db.Decimal(16, 2)
  numberOfBowsers  Int?
  deliveryLocation String?
  deliveredQty     Decimal            @default(0) @db.Decimal(16, 3)
  contractStatus   ContractStatus     @default(OPEN)
  saleStatus       SaleContractStatus @default(OPEN)
  isDollar         Boolean            @default(false)
  rateUsd          Decimal?           @db.Decimal(16, 4)
  remarks          String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  deliveries SaleDelivery[]

  @@unique([companyId, contractNo])
  @@index([companyId, saleStatus])
}

model SaleDelivery {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String
  contractId      String?
  customerId      String
  productId       String
  locationId      String
  vehicleId       String?
  transporterId   String?
  deliveryWeight  Decimal       @default(0) @db.Decimal(16, 3)
  loadWeight      Decimal       @default(0) @db.Decimal(16, 3)
  quantity        Decimal       @db.Decimal(16, 3)
  unit            UnitOfMeasure @default(MT)
  rate            Decimal       @default(0) @db.Decimal(16, 4)
  finalRate       Decimal       @default(0) @db.Decimal(16, 4)
  amount          Decimal       @default(0) @db.Decimal(16, 2)
  isDollar        Boolean       @default(false)
  transactionDate DateTime      @db.Date
  voucherId       String?
  remarks         String?
  createdById     String
  createdAt       DateTime      @default(now())

  contract SaleContract? @relation(fields: [contractId], references: [id])

  @@unique([companyId, documentNo])
  @@index([companyId, transactionDate])
}

model LossGain {
  id               String       @id @default(cuid())
  companyId        String
  financialYearId  String
  documentNo       String
  type             LossGainType
  productId        String
  locationId       String
  expectedQuantity Decimal      @db.Decimal(16, 3)
  actualQuantity   Decimal      @db.Decimal(16, 3)
  difference       Decimal      @db.Decimal(16, 3)
  rate             Decimal      @default(0) @db.Decimal(16, 4)
  financialImpact  Decimal      @default(0) @db.Decimal(16, 2)
  reason           String?
  status           ApprovalStatus @default(PENDING)
  postedToPl       Boolean      @default(false)
  voucherId        String?
  transactionDate  DateTime     @db.Date
  createdById      String
  approvedById     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([companyId, documentNo])
  @@index([companyId, status])
}

model DollarTransaction {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String
  txnType         DollarTxnType
  partyType       PartyType?
  customerId      String?
  vendorId        String?
  contractId      String?
  usdAmount       Decimal       @db.Decimal(16, 2)
  exchangeRate    Decimal       @db.Decimal(12, 4)
  pkrAmount       Decimal       @db.Decimal(16, 2)
  exchangeGainLoss Decimal      @default(0) @db.Decimal(16, 2)
  productId       String?
  quantity        Decimal?      @db.Decimal(16, 3)
  locationId      String?
  voucherId       String?
  transactionDate DateTime      @db.Date
  remarks         String?
  createdById     String
  createdAt       DateTime      @default(now())

  @@unique([companyId, documentNo])
  @@index([companyId, txnType, transactionDate])
}

model PlantSale {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String
  saleType        PlantSaleType
  invoiceNo       String?
  plantId         String
  locationId      String
  customerId      String
  productId       String?
  quantity        Decimal       @db.Decimal(16, 3)
  unit            UnitOfMeasure @default(MT)
  rate            Decimal       @default(0) @db.Decimal(16, 4)
  amount          Decimal       @default(0) @db.Decimal(16, 2)
  transporterId   String?
  vehicleId       String?
  paymentStatus   String?
  isDollar        Boolean       @default(false)
  transactionDate DateTime      @db.Date
  voucherId       String?
  remarks         String?
  createdById     String
  createdAt       DateTime      @default(now())

  @@unique([companyId, documentNo])
  @@index([companyId, saleType, transactionDate])
}

model PlantTransfer {
  id              String        @id @default(cuid())
  companyId       String
  financialYearId String
  documentNo      String
  fromPlantId     String
  toPlantId       String
  fromLocationId  String
  toLocationId    String
  productId       String
  quantity        Decimal       @db.Decimal(16, 3)
  unit            UnitOfMeasure @default(MT)
  vehicleId       String?
  transporterId   String?
  transactionDate DateTime      @db.Date
  remarks         String?
  createdById     String
  createdAt       DateTime      @default(now())

  @@unique([companyId, documentNo])
  @@index([companyId, transactionDate])
}

model PartialReceiving {
  id                 String         @id @default(cuid())
  companyId          String
  financialYearId    String
  documentNo         String
  vehicleId          String?
  loadedFromLocation String?
  plantId            String
  locationId         String
  productId          String
  dispatchWeight     Decimal        @db.Decimal(16, 3)
  totalQuantity      Decimal        @db.Decimal(16, 3)
  receivedQuantity   Decimal        @default(0) @db.Decimal(16, 3)
  remainingQuantity  Decimal        @db.Decimal(16, 3)
  unit               UnitOfMeasure  @default(MT)
  amount             Decimal        @default(0) @db.Decimal(16, 2)
  transporterId      String?
  loadWeight         Decimal        @default(0) @db.Decimal(16, 3)
  finalRate          Decimal        @default(0) @db.Decimal(16, 4)
  saleStatus         String?
  arrivalStatus      ShipmentStatus @default(IN_TRANSIT)
  transactionDate    DateTime       @db.Date
  remarks            String?
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  events PartialReceivingEvent[]

  @@unique([companyId, documentNo])
  @@index([companyId, arrivalStatus])
}

model PartialReceivingEvent {
  id                 String   @id @default(cuid())
  partialReceivingId String
  quantityReceived   Decimal  @db.Decimal(16, 3)
  receivedDate       DateTime @db.Date
  remarks            String?
  createdById        String
  createdAt          DateTime @default(now())

  partialReceiving PartialReceiving @relation(fields: [partialReceivingId], references: [id], onDelete: Cascade)

  @@index([partialReceivingId])
}
